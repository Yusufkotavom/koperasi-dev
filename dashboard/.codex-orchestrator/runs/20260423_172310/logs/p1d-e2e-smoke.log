            </div>
            <div className="flex">
              <span className="w-32 font-semibold">Wajib Angsur</span>
              <span className="font-bold">: {fmt(tagihanPerPeriode)} / {pinjaman.tenorType === "MINGGUAN" ? "minggu" : "bulan"}</span>
