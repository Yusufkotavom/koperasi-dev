+function parseNomorAnggotaSeq(nomorAnggota: string, prefix: string): number | null {
+  if (!nomorAnggota.startsWith(prefix)) return null
+  const rawSeq = nomorAnggota.slice(prefix.length)
+  if (!/^\d+$/.test(rawSeq)) return null
+  const parsed = Number.parseInt(rawSeq, 10)
+  return Number.isFinite(parsed) ? parsed : null
+}
+
+async function lockNomorAnggotaSequence(tx: Prisma.TransactionClient, companyId: string) {
+  const lockKey = `nasabah-nomor-anggota:${companyId}`
+  await tx.$queryRaw`SELECT pg_advisory_xact_lock(hashtext(${lockKey})::bigint)`
+}
+
+// Helper: generate nomor anggota otomatis (transaction-safe)
+async function generateNomorAnggota(tx: Prisma.TransactionClient, companyId: string): Promise<string> {
   const year = new Date().getFullYear().toString().slice(2)
-  return `N-${year}-${seq}`
+  const prefix = `N-${year}-`
+
+  const [count, latestInYear] = await Promise.all([
+    tx.nasabah.count({ where: { companyId } }),
+    tx.nasabah.findFirst({
+      where: { companyId, nomorAnggota: { startsWith: prefix } },
+      orderBy: { nomorAnggota: "desc" },
+      select: { nomorAnggota: true },
+    }),
+  ])
+
+  const seq = String(count + 1).padStart(4, "0")
+  const latestSeq = latestInYear ? parseNomorAnggotaSeq(latestInYear.nomorAnggota, prefix) : null
+  const nextSeq = latestSeq && latestSeq >= Number(seq) ? latestSeq + 1 : Number(seq)
+
+  return `${prefix}${String(nextSeq).padStart(4, "0")}`
 }
 
