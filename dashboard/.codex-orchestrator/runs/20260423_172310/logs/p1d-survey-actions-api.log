import { createNasabahSurveyNote, listNasabahSurveyNotes } from \"@/actions/nasabah-survey\"

type RouteContext = {
  params: Promise<{ id: string }>
}

function ok<T>(data: T, status = 200) {
  return Response.json({ success: true, data }, { status })
}

function fail(error: string, status: number, details?: unknown) {
  return Response.json(
    {
      success: false,
      error,
      ...(details "'!== undefined ? { details } : {}),
    },
    { status },
  )
}

async function resolveNasabahId(ctx: RouteContext) {
  const { id } = await ctx.params
  return id?.trim() ?? ""
}

export async function GET(_request: Request, context: RouteContext) {
  const nasabahId = await resolveNasabahId(context)
  if (!nasabahId) return fail("ID nasabah tidak valid.", 400)

  const result = await listNasabahSurveyNotes(nasabahId)
  if (!result.success) {
    return fail(result.error, result.status, result.details)
  }

  return ok(result.data)
}

export async function POST(request: Request, context: RouteContext) {
  const nasabahId = await resolveNasabahId(context)
  if (!nasabahId) return fail("ID nasabah tidak valid.", 400)

  let payload: unknown
  try {
    payload = await request.json()
  } catch {
    return fail("Body JSON tidak valid.", 400)
  }

  const result = await createNasabahSurveyNote(nasabahId, payload)
  if (!result.success) {
    return fail(result.error, result.status, result.details)
  }

  return ok(result.data, result.status)
}
