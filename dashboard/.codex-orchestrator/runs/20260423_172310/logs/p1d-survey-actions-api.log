\"use server\"

import { RoleType, type StatusPengajuan } from \"@prisma/client\"
import { z } from \"zod\"
import { auth } from \"@/lib/auth\"
import { prisma } from \"@/lib/prisma\"
import { requireRoles } from \"@/lib/roles\"
import { requireCompanyId } from \"@/lib/tenant\"

const ALLOWED_SURVEY_ROLES: RoleType[] = [
  RoleType.OWNER,
  RoleType.ADMIN,
  RoleType.MANAGER,
  RoleType.PIMPINAN,
  RoleType.SURVEYOR,
]

const createSurveySchema = z.object({
  note: z.string().trim().min(1, \"Catatan survey wajib diisi.\").max(2000, \"Catatan survey maksimal 2000 karakter.\"),
  pengajuanId: z.string().trim().min(1).optional(),
})

type SessionLike = { user?: { id?: string; companyId?: string | null; roles?: string[] } } | null

type SurveyNoteItem = {
  id: string
  pengajuanId: string
  note: string
  statusPengajuan: StatusPengajuan
  tanggalSurvey: string | null
  surveyor: { id: string; name: string | null } | null
}

type ActionSuccess<T> = { success: true; status: number; data: T }
type ActionError = { success: false; status: number; error: string; details?: unknown }

function mapAuthError(error: unknown): ActionError {
  const message = error instanceof Error ? error.message : \"Unauthorized\"

  if (message === \"Unauthorized\") {
    return { success: false, status: 401, error: \"Unauthorized\" }
  }

  if (message === \"Forbidden\") {
    return { success: false, status: 403, error: \"Forbidden\" }
  }

  return { success: false, status: 400, error: message }
}

async function resolveContext() {
  const session = await auth()
  if ("'!session) return { success: false, status: 401, error: "Unauthorized" } as const

  try {
    const { userId } = requireRoles(session as SessionLike, ALLOWED_SURVEY_ROLES)
    const { companyId } = requireCompanyId(session as SessionLike)

    return { success: true, userId, companyId } as const
  } catch (error) {
    return mapAuthError(error)
  }
}

function toSurveyItem(input: {
  id: string
  hasilSurvey: string | null
  status: StatusPengajuan
  tanggalSurvey: Date | null
  surveyor: { id: string; name: string | null } | null
}): SurveyNoteItem {
  return {
    id: input.id,
    pengajuanId: input.id,
    note: input.hasilSurvey?.trim() ?? "",
    statusPengajuan: input.status,
    tanggalSurvey: input.tanggalSurvey?.toISOString() ?? null,
    surveyor: input.surveyor,
  }
}

export async function listNasabahSurveyNotes(
  nasabahId: string,
): Promise<ActionSuccess<{ nasabahId: string; items: SurveyNoteItem[] }> | ActionError> {
  const ctx = await resolveContext()
  if (!ctx.success) return ctx

  try {
    const nasabah = await prisma.nasabah.findFirst({
      where: { id: nasabahId, companyId: ctx.companyId },
      select: { id: true },
    })

    if (!nasabah) {
      return { success: false, status: 404, error: "Nasabah tidak ditemukan." }
    }

    const rows = await prisma.pengajuan.findMany({
      where: {
        companyId: ctx.companyId,
        nasabahId,
        hasilSurvey: { not: null },
      },
      orderBy: [{ tanggalSurvey: "desc" }, { updatedAt: "desc" }],
      select: {
        id: true,
        hasilSurvey: true,
        status: true,
        tanggalSurvey: true,
        surveyor: { select: { id: true, name: true } },
      },
    })

    const items = rows
      .map(toSurveyItem)
      .filter((item) => item.note.length > 0)

    return {
      success: true,
      status: 200,
      data: {
        nasabahId,
        items,
      },
    }
  } catch (error) {
    const message = error instanceof Error ? error.message : "Gagal mengambil catatan survey."
    return { success: false, status: 500, error: message }
  }
}

export async function createNasabahSurveyNote(
  nasabahId: string,
  input: unknown,
): Promise<ActionSuccess<{ item: SurveyNoteItem }> | ActionError> {
  const ctx = await resolveContext()
  if (!ctx.success) return ctx

  const parsed = createSurveySchema.safeParse(input)
  if (!parsed.success) {
    return {
      success: false,
      status: 400,
      error: "Input tidak valid.",
      details: parsed.error.flatten().fieldErrors,
    }
  }

  try {
    const nasabah = await prisma.nasabah.findFirst({
      where: { id: nasabahId, companyId: ctx.companyId },
      select: { id: true },
    })

    if (!nasabah) {
      return { success: false, status: 404, error: "Nasabah tidak ditemukan." }
    }

    const targetPengajuan = await prisma.pengajuan.findFirst({
      where: {
        companyId: ctx.companyId,
        nasabahId,
        ...(parsed.data.pengajuanId ? { id: parsed.data.pengajuanId } : {}),
      },
      orderBy: parsed.data.pengajuanId ? undefined : [{ createdAt: "desc" }],
      select: {
        id: true,
        hasilSurvey: true,
        status: true,
      },
    })

    if (!targetPengajuan) {
      return { success: false, status: 404, error: "Pengajuan untuk survey tidak ditemukan." }
    }

    if (targetPengajuan.hasilSurvey?.trim()) {
      return {
        success: false,
        status: 409,
        error: "Catatan survey untuk pengajuan ini sudah ada.",
      }
    }

    const updated = await prisma.pengajuan.update({
      where: { id: targetPengajuan.id },
      data: {
        hasilSurvey: parsed.data.note,
        tanggalSurvey: new Date(),
        surveyorId: ctx.userId,
        status: targetPengajuan.status === "DRAFT" || targetPengajuan.status === "DIAJUKAN" ? "DISURVEY" : targetPengajuan.status,
      },
      select: {
        id: true,
        hasilSurvey: true,
        status: true,
        tanggalSurvey: true,
        surveyor: { select: { id: true, name: true } },
      },
    })

    return {
      success: true,
      status: 201,
      data: {
        item: toSurveyItem(updated),
      },
    }
  } catch (error) {
    const message = error instanceof Error ? error.message : "Gagal menyimpan catatan survey."
    return { success: false, status: 500, error: message }
  }
}
