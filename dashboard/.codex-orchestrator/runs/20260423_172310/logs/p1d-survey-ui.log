diff --git a/dashboard/src/app/api/nasabah/[id]/survey/route.ts b/dashboard/src/app/api/nasabah/[id]/survey/route.ts
new file mode 100644
index 0000000000000000000000000000000000000000..c899995e25550114842bcdcf6479242d4c4ba8ed
