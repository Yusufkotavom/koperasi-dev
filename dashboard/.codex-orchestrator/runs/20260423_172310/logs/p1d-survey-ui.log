@@ -0,0 +1,114 @@
+import { AuditAction } from "@prisma/client"
+import { auth } from "@/lib/auth"
+import { prisma } from "@/lib/prisma"
+import { requireCompanyId } from "@/lib/tenant"
+
+type RouteContext = {
+  params: Promise<{ id: string }>
+}
+
+const SURVEY_ENTITY_TYPE = "NASABAH_SURVEY"
+
+function getSessionCompany(session: Awaited<ReturnType<typeof auth>>) {
+  return requireCompanyId(
+    session as unknown as {
+      user?: { id?: string; companyId?: string | null; roles?: string[] }
+    } | null,
+  )
+}
+
+async function assertNasabahInCompany(nasabahId: string, companyId: string) {
+  const nasabah = await prisma.nasabah.findFirst({
+    where: { id: nasabahId, companyId },
+    select: { id: true },
+  })
+  return Boolean(nasabah)
+}
+
+export async function GET(_req: Request, ctx: RouteContext) {
+  try {
+    const session = await auth()
+    if (!session) return Response.json({ error: "Unauthorized" }, { status: 401 })
+
+    const { id: nasabahId } = await ctx.params
+    const { companyId } = getSessionCompany(session)
+    const exists = await assertNasabahInCompany(nasabahId, companyId)
+    if (!exists) return Response.json({ error: "Nasabah tidak ditemukan." }, { status: 404 })
+
+    const notes = await prisma.auditLog.findMany({
+      where: { entityType: SURVEY_ENTITY_TYPE, entityId: nasabahId, action: AuditAction.CREATE },
+      orderBy: { createdAt: "desc" },
+      include: { actor: { select: { name: true } } },
+    })
+
+    return Response.json({
+      data: notes.map((item) => {
+        const metadata = (item.metadata ?? {}) as { note?: string; message?: string }
+        return {
+          id: item.id,
+          note: typeof metadata.note === "string" ? metadata.note : (typeof metadata.message === "string" ? metadata.message : ""),
+          createdAt: item.createdAt,
+          createdById: item.actorId,
+          createdByName: item.actor?.name ?? "Sistem",
+        }
+      }),
+    })
+  } catch (error) {
+    const message = error instanceof Error ? error.message : "Gagal memuat catatan survey."
+    if (message === "Company context required" || message === "Akun belum terhubung ke company.") {
+      return Response.json({ error: message }, { status: 403 })
+    }
+    if (message === "Unauthorized") return Response.json({ error: message }, { status: 401 })
+    return Response.json({ error: "Gagal memuat catatan survey." }, { status: 500 })
+  }
+}
+
+export async function POST(req: Request, ctx: RouteContext) {
+  try {
+    const session = await auth()
+    if (!session) return Response.json({ error: "Unauthorized" }, { status: 401 })
+
+    const { id: nasabahId } = await ctx.params
+    const { companyId, userId } = getSessionCompany(session)
+    const exists = await assertNasabahInCompany(nasabahId, companyId)
+    if (!exists) return Response.json({ error: "Nasabah tidak ditemukan." }, { status: 404 })
+
+    const body = (await req.json().catch(() => ({}))) as { note?: unknown }
+    const note = typeof body.note === "string" ? body.note.trim() : ""
+    if (!note) return Response.json({ error: "Catatan survey wajib diisi." }, { status: 400 })
+    if (note.length > 1000) {
+      return Response.json({ error: "Catatan survey maksimal 1000 karakter." }, { status: 400 })
+    }
+
+    const saved = await prisma.auditLog.create({
+      data: {
+        actorId: userId,
+        entityType: SURVEY_ENTITY_TYPE,
+        entityId: nasabahId,
+        action: AuditAction.CREATE,
+        metadata: { note },
+      },
+      include: { actor: { select: { name: true } } },
+    })
+
+    return Response.json(
+      {
+        data: {
+          id: saved.id,
+          note,
+          createdAt: saved.createdAt,
+          createdById: saved.actorId,
+          createdByName: saved.actor?.name ?? "Sistem",
+        },
+      },
+      { status: 201 },
+    )
+  } catch (error) {
+    const message = error instanceof Error ? error.message : "Gagal menyimpan catatan survey."
+    if (message === "Company context required" || message === "Akun belum terhubung ke company.") {
+      return Response.json({ error: message }, { status: 403 })
+    }
+    if (message === "Unauthorized") return Response.json({ error: message }, { status: 401 })
+    return Response.json({ error: "Gagal menyimpan catatan survey." }, { status: 500 })
+  }
+}

