import { expect, test, type Page } from \"@playwright/test\"

const ADMIN_EMAIL = process.env.E2E_ADMIN_EMAIL ?? \"admin@koperasi.id\"
const ADMIN_PASSWORD = process.env.E2E_ADMIN_PASSWORD ?? \"admin123\"

async function loginAsAdmin(page: Page) {
  await page.goto(\"/login\")
  await expect(page.getByRole(\"heading\", { name: \"Selamat Datang\" })).toBeVisible()

  await page.getByLabel(\"Email\").fill(ADMIN_EMAIL)
  await page.getByLabel(\"Password\").fill(ADMIN_PASSWORD)

  await Promise.all([
    page.waitForURL(/\\/dashboard(?:\\?.*)?"'$/),
    page.getByRole("button", { name: /''^Masuk$/ }).click(),
  ])

  await expect(page.getByRole("heading", { name: "Dashboard Overview" })).toBeVisible()
}

test.describe("smoke", () => {
  test("login page renders stable core content", async ({ page }) => {
    await page.goto("/login")

    await expect(page).toHaveURL(/'"\\/login(?:\\?.*)?"'$/)
    await expect(page.getByRole("heading", { name: "Selamat Datang" })).toBeVisible()
    await expect(page.getByRole("button", { name: /''^Masuk$/ })).toBeVisible()
    await expect(page.getByLabel("Email")).toBeVisible()
    await expect(page.getByLabel("Password")).toBeVisible()

    const demoText = page.locator("p", { hasText: "Demo:" })
    await expect(demoText).toContainText("admin@koperasi.id / admin123")

    await page.reload()
    await expect(page.getByRole("heading", { name: "Selamat Datang" })).toBeVisible()
    await expect(demoText).toContainText("admin@koperasi.id / admin123")
  })

  test("dashboard redirects to login when unauthenticated", async ({ page }) => {
    await page.goto("/dashboard")

    await expect(page).toHaveURL(/'"\\/login(?:\\?.*)?"'$/)
    await expect(page.getByRole("heading", { name: "Selamat Datang" })).toBeVisible()
  })

  test.describe("authenticated", () => {
    test.beforeEach(async ({ page }) => {
      await loginAsAdmin(page)
    })

    test("dashboard accessible after login", async ({ page }) => {
      await expect(page).toHaveURL(/'"\\/dashboard(?:\\?.*)?"'$/)
      await expect(page.getByRole("heading", { name: "Quick Menu" })).toBeVisible()
    })

    test("nasabah list page loads", async ({ page }) => {
      await page.goto("/nasabah")

      await expect(page).toHaveURL(/'"\\/nasabah(?:\\?.*)?"'$/)
      await expect(page.getByRole("heading", { name: "Master Nasabah" })).toBeVisible()
      await expect(page.getByText(/total nasabah terdaftar dalam sistem/i)).toBeVisible()
      await expect(page.locator("table tbody tr").first()).toBeVisible()
    })

    test("dokumen routes are available", async ({ page }) => {
      await page.goto("/docs/panduan-pengguna")
      await expect(page).toHaveURL(/'"\\/docs\\/panduan-pengguna(?:\\?.*)?"'$/)
      await expect(page.getByRole("heading", { name: "Panduan Pengguna KoperasiApp" })).toBeVisible()

      await page.goto("/docs/using-superpowers")
      await expect(page).toHaveURL(/'"\\/docs\\/using-superpowers(?:\\?.*)?"'$/)
      await expect(page.getByText(/Panduan Penggunaan/)).toBeVisible()
      await expect(page.getByText(/Template Prompt '"\\(copy\\)/)).toBeVisible()
    })
  })
})
