\"use server\"

import { RoleType, type Prisma } from \"@prisma/client\"
import { z } from \"zod\"
import { auth } from \"@/lib/auth\"
import { prisma } from \"@/lib/prisma\"
import { requireCompanyId } from \"@/lib/tenant\"
import { requireRoles } from \"@/lib/roles\"

const SURVEY_NOTE_ENTITY_TYPE = \"NASABAH_SURVEY_NOTE\"
const MAX_SURVEY_NOTE_LENGTH = 1500

const nasabahIdSchema = z.string().trim().min(1, \"ID nasabah wajib diisi.\")
const createSurveyNoteSchema = z.object({
  note: z
    .string()
    .trim()
    .min(1, \"Catatan survey wajib diisi.\")
    .max(MAX_SURVEY_NOTE_LENGTH, "'`Catatan survey maksimal ${MAX_SURVEY_NOTE_LENGTH} karakter.`),
})

type ApiError = {
  success: false
  error: {
    code: string
    message: string
    details?: unknown
  }
}

type ApiSuccess<T> = {
  success: true
  data: T
}

type ApiResult<T> = {
  status: number
  body: ApiSuccess<T> | ApiError
}

type SurveyNoteItem = {
  id: string
  note: string
  createdAt: string
  createdBy: {
    id: string
    name: string | null
    email: string | null
  } | null
}

function ok<T>(status: number, data: T): ApiResult<T> {
  return { status, body: { success: true, data } }
}

function fail(status: number, code: string, message: string, details?: unknown): ApiResult<never> {
  return {
    status,
    body: {
      success: false,
      error: {
        code,
        message,
        ...(details !== undefined ? { details } : {}),
      },
    },
  }
}

function getNoteFromJson(json: Prisma.JsonValue | null): string {
  if (!json || typeof json !== "object" || Array.isArray(json)) return ""
  const candidate = (json as Record<string, unknown>).note
  return typeof candidate === "string" ? candidate : ""
}

function mapSurveyNote(row: {
  id: string
  createdAt: Date
  actor: { id: string; name: string | null; email: string | null } | null
  afterData: Prisma.JsonValue | null
}): SurveyNoteItem {
  return {
    id: row.id,
    note: getNoteFromJson(row.afterData),
    createdAt: row.createdAt.toISOString(),
    createdBy: row.actor
      ? {
          id: row.actor.id,
          name: row.actor.name,
          email: row.actor.email,
        }
      : null,
  }
}

async function ensureNasabahInCompany(companyId: string, nasabahId: string) {
  const nasabah = await prisma.nasabah.findFirst({
    where: { id: nasabahId, companyId },
    select: { id: true },
  })

  return Boolean(nasabah)
}

const VIEW_ROLES: RoleType[] = [
  RoleType.OWNER,
  RoleType.ADMIN,
  RoleType.MANAGER,
  RoleType.PIMPINAN,
  RoleType.SURVEYOR,
  RoleType.KOLEKTOR,
]

const CREATE_ROLES: RoleType[] = [
  RoleType.OWNER,
  RoleType.ADMIN,
  RoleType.MANAGER,
  RoleType.PIMPINAN,
  RoleType.SURVEYOR,
]

export async function listNasabahSurveyNotes(nasabahIdInput: string): Promise<ApiResult<{ notes: SurveyNoteItem[] }>> {
  const session = await auth()
  if (!session) return fail(401, "UNAUTHORIZED", "Unauthorized")

  const parsedNasabahId = nasabahIdSchema.safeParse(nasabahIdInput)
  if (!parsedNasabahId.success) {
    return fail(400, "INVALID_NASABAH_ID", "ID nasabah tidak valid.", parsedNasabahId.error.flatten().fieldErrors)
  }

  const nasabahId = parsedNasabahId.data

  let companyId: string
  try {
    companyId = requireCompanyId(
      session as unknown as { user?: { id?: string; companyId?: string | null; roles?: string[] } } | null,
    ).companyId
  } catch (error) {
    const message = error instanceof Error ? error.message : "Unauthorized"
    if (message === "Unauthorized") return fail(401, "UNAUTHORIZED", "Unauthorized")
    return fail(403, "FORBIDDEN", message)
  }

  try {
    requireRoles(session, VIEW_ROLES)
  } catch {
    return fail(403, "FORBIDDEN", "Tidak memiliki hak akses untuk melihat catatan survey.")
  }

  try {
    const exists = await ensureNasabahInCompany(companyId, nasabahId)
    if (!exists) {
      return fail(404, "NASABAH_NOT_FOUND", "Nasabah tidak ditemukan.")
    }

    const rows = await prisma.auditLog.findMany({
      where: {
        entityType: SURVEY_NOTE_ENTITY_TYPE,
        entityId: nasabahId,
      },
      orderBy: { createdAt: "desc" },
      select: {
        id: true,
        createdAt: true,
        afterData: true,
        actor: {
          select: {
            id: true,
            name: true,
            email: true,
          },
        },
      },
    })

    const notes = rows.map(mapSurveyNote).filter((item) => item.note.trim().length > 0)
    return ok(200, { notes })
  } catch (error) {
    console.error("[listNasabahSurveyNotes]", error)
    return fail(500, "INTERNAL_ERROR", "Gagal mengambil catatan survey.")
  }
}

export async function createNasabahSurveyNote(
  nasabahIdInput: string,
  payload: unknown,
): Promise<ApiResult<{ note: SurveyNoteItem }>> {
  const session = await auth()
  if (!session) return fail(401, "UNAUTHORIZED", "Unauthorized")

  const parsedNasabahId = nasabahIdSchema.safeParse(nasabahIdInput)
  if (!parsedNasabahId.success) {
    return fail(400, "INVALID_NASABAH_ID", "ID nasabah tidak valid.", parsedNasabahId.error.flatten().fieldErrors)
  }

  let companyId: string
  let userId: string
  try {
    const scoped = requireCompanyId(
      session as unknown as { user?: { id?: string; companyId?: string | null; roles?: string[] } } | null,
    )
    companyId = scoped.companyId
    userId = scoped.userId
  } catch (error) {
    const message = error instanceof Error ? error.message : "Unauthorized"
    if (message === "Unauthorized") return fail(401, "UNAUTHORIZED", "Unauthorized")
    return fail(403, "FORBIDDEN", message)
  }

  try {
    requireRoles(session, CREATE_ROLES)
  } catch {
    return fail(403, "FORBIDDEN", "Tidak memiliki hak akses untuk menulis catatan survey.")
  }

  const parsedBody = createSurveyNoteSchema.safeParse(payload)
  if (!parsedBody.success) {
    return fail(400, "VALIDATION_ERROR", "Input tidak valid.", parsedBody.error.flatten().fieldErrors)
  }

  const nasabahId = parsedNasabahId.data

  try {
    const exists = await ensureNasabahInCompany(companyId, nasabahId)
    if (!exists) {
      return fail(404, "NASABAH_NOT_FOUND", "Nasabah tidak ditemukan.")
    }

    const created = await prisma.auditLog.create({
      data: {
        actorId: userId,
        entityType: SURVEY_NOTE_ENTITY_TYPE,
        entityId: nasabahId,
        action: "CREATE",
        afterData: {
          note: parsedBody.data.note,
        },
        metadata: {
          companyId,
          nasabahId,
          source: "api.nasabah.survey",
        },
      },
      select: {
        id: true,
        createdAt: true,
        afterData: true,
        actor: {
          select: {
            id: true,
            name: true,
            email: true,
          },
        },
      },
    })

    return ok(201, { note: mapSurveyNote(created) })
  } catch (error) {
    console.error("[createNasabahSurveyNote]", error)
    return fail(500, "INTERNAL_ERROR", "Gagal menyimpan catatan survey.")
  }
}
