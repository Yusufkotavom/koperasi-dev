import { auth } from \"@/lib/auth\"
import { prisma } from \"@/lib/prisma\"
import { requireCompanyId } from \"@/lib/tenant\"

type SurveyEvent = {
  id: string
  pengajuanId: string
  createdAt: string
  note: string
  surveyorName: string | null
  status: string
}

const SURVEY_NOTE_PATTERN = /"'^'"\\[(?<ts>["'^'"\\]]+)\\]\\s*(?<text>.*)"'$/

function parseSurveyNotes(raw: string | null | undefined, fallbackDate: Date | null | undefined): Array<{ createdAt: Date; note: string }> {
  const source = (raw ?? "").trim()
  if (!source) return []

  const lines = source
    .split("'"\\n\")
    .map((line) => line.trim())
    .filter(Boolean)

  const parsed = lines.flatMap((line) => {
    const match = line.match(SURVEY_NOTE_PATTERN)
    if ("'!match?.groups) return []

    const text = match.groups.text?.trim() ?? ""
    if (!text) return []

    const asDate = new Date(match.groups.ts)
    if (Number.isNaN(asDate.getTime())) return []

    return [{ createdAt: asDate, note: text }]
  })

  if (parsed.length > 0) return parsed

  return [{ createdAt: fallbackDate ?? new Date(0), note: source }]
}

function serializeTimeline(rows: Array<{
  id: string
  status: string
  tanggalSurvey: Date | null
  updatedAt: Date
  hasilSurvey: string | null
  surveyor: { name: string } | null
}>): SurveyEvent[] {
  const events = rows.flatMap((row) => {
    const notes = parseSurveyNotes(row.hasilSurvey, row.tanggalSurvey ?? row.updatedAt)

    return notes.map((item, index) => ({
      id: `${row.id}:${index}:${item.createdAt.toISOString()}`,
      pengajuanId: row.id,
      createdAt: item.createdAt.toISOString(),
      note: item.note,
      surveyorName: row.surveyor?.name ?? null,
      status: row.status,
    }))
  })

  return events.sort((a, b) => new Date(b.createdAt).getTime() - new Date(a.createdAt).getTime())
}

export async function GET(_: Request, ctx: RouteContext<"/api/nasabah/[id]/survey">) {
  const session = await auth()
  if (!session) {
    return Response.json({ error: "Unauthorized" }, { status: 401 })
  }

  let companyId: string
  try {
    companyId = requireCompanyId(session as unknown as { user?: { id?: string; companyId?: string | null; roles?: string[] } } | null).companyId
  } catch (error) {
    const message = error instanceof Error ? error.message : "Unauthorized"
    return Response.json({ error: message }, { status: 403 })
  }

  const { id } = await ctx.params

  const nasabah = await prisma.nasabah.findFirst({
    where: { id, companyId },
    select: {
      id: true,
      pengajuan: {
        orderBy: { tanggalPengajuan: "desc" },
        select: {
          id: true,
          status: true,
          hasilSurvey: true,
          tanggalSurvey: true,
          updatedAt: true,
          surveyor: { select: { name: true } },
        },
      },
    },
  })

  if (!nasabah) {
    return Response.json({ error: "Nasabah tidak ditemukan." }, { status: 404 })
  }

  const events = serializeTimeline(nasabah.pengajuan)
  return Response.json({ items: events })
}

export async function POST(req: Request, ctx: RouteContext<"/api/nasabah/[id]/survey">) {
  const session = await auth()
  if (!session) {
    return Response.json({ error: "Unauthorized" }, { status: 401 })
  }

  let companyId: string
  let userId: string
  try {
    const company = requireCompanyId(session as unknown as { user?: { id?: string; companyId?: string | null; roles?: string[] } } | null)
    companyId = company.companyId
    userId = company.userId
  } catch (error) {
    const message = error instanceof Error ? error.message : "Unauthorized"
    return Response.json({ error: message }, { status: 403 })
  }

  const body = (await req.json().catch(() => null)) as { note?: unknown; pengajuanId?: unknown } | null
  const note = typeof body?.note === "string" ? body.note.trim() : ""
  const pengajuanIdInput = typeof body?.pengajuanId === "string" ? body.pengajuanId : ""

  if (!note) {
    return Response.json({ error: "Catatan survei wajib diisi." }, { status: 400 })
  }

  if (note.length > 1000) {
    return Response.json({ error: "Catatan survei maksimal 1000 karakter." }, { status: 400 })
  }

  const { id: nasabahId } = await ctx.params

  const nasabah = await prisma.nasabah.findFirst({
    where: { id: nasabahId, companyId },
    select: {
      id: true,
      pengajuan: {
        orderBy: { tanggalPengajuan: "desc" },
        select: {
          id: true,
          status: true,
          hasilSurvey: true,
        },
      },
    },
  })

  if (!nasabah) {
    return Response.json({ error: "Nasabah tidak ditemukan." }, { status: 404 })
  }

  const selectedPengajuan = pengajuanIdInput
    ? nasabah.pengajuan.find((item) => item.id === pengajuanIdInput)
    : nasabah.pengajuan[0]

  if (!selectedPengajuan) {
    return Response.json({ error: "Belum ada pengajuan untuk nasabah ini." }, { status: 400 })
  }

  const now = new Date()
  const timestamped = `[${now.toISOString()}] ${note}`
  const merged = selectedPengajuan.hasilSurvey?.trim()
    ? `${selectedPengajuan.hasilSurvey.trim()}'"\\n"'${timestamped}`
    : timestamped

  const updated = await prisma.pengajuan.update({
    where: { id: selectedPengajuan.id },
    data: {
      hasilSurvey: merged,
      tanggalSurvey: now,
      surveyorId: userId,
      ...(selectedPengajuan.status === "DIAJUKAN" ? { status: "DISURVEY" as const } : {}),
    },
    select: {
      id: true,
      status: true,
      hasilSurvey: true,
      tanggalSurvey: true,
      updatedAt: true,
      surveyor: { select: { name: true } },
    },
  })

  const latestEvent = serializeTimeline([updated])[0]

  return Response.json({
    item: latestEvent,
    message: "Catatan survei berhasil ditambahkan.",
  })
}
