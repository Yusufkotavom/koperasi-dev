        <Button variant="outline" size="sm" asChild>
          <a href="#penjamin">Penjamin ({nasabah.penjamin.length})</a>
        </Button>
        <Button variant="outline" size="sm" asChild>
          <a href="#dokumen">Dokumen ({nasabah.dokumenUrls.length})</a>
        </Button>
        <Button variant="outline" size="sm" asChild>
          <a href="#pengajuan">Pengajuan ({nasabah.pengajuan.length})</a>
