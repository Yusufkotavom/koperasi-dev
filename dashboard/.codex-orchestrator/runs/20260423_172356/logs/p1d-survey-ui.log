  jadwalPertemuan String?
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt
  companyId       String
  company         Company     @relation(fields: [companyId], references: [id], onDelete: Cascade)
  nasabah         Nasabah[]
  pengajuan       Pengajuan[]

  @@unique([companyId, kode])
  @@index([companyId])
  @@map("kelompok")
}

