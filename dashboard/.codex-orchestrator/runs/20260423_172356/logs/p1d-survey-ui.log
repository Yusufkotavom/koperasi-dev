          <p className="text-muted-foreground text-sm font-mono">{nasabah.nomorAnggota}</p>
        </div>
      </div>

      <EditNasabahForm nasabah={nasabah} kelompokList={kelompokList} kolektorList={kolektorList} />
    </div>
  )
}

