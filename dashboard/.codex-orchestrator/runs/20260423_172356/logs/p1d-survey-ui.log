  createdAt: string
  note: string
  surveyorName: string | null
  status: string
}

type SurveyResponse = {
  items?: SurveyItem[]
  item?: SurveyItem
  error?: string
  message?: string
}

const statusClass: Record<string, string> = {
  DIAJUKAN: \"bg-blue-100 text-blue-700\",
  DISURVEY: \"bg-violet-100 text-violet-700\",
  DISETUJUI: \"bg-emerald-100 text-emerald-700\",
  DITOLAK: \"bg-red-100 text-red-700\",
  DICAIRKAN: \"bg-teal-100 text-teal-700\",
  SELESAI: \"bg-slate-100 text-slate-700\",
}

function fmtDateTime(value: string) {
  const dt = new Date(value)
  if (Number.isNaN(dt.getTime())) return \"Waktu tidak valid\"
  return new Intl.DateTimeFormat(\"id-ID\", {
    day: \"2-digit\",
    month: \"short\",
    year: \"numeric\",
    hour: \"2-digit\",
    minute: \"2-digit\",
  }).format(dt)
}

export function SurveyTimelineCard({
  nasabahId,
  allowQuickAdd = false,
  title = \"Timeline Survey\",
}: {
  nasabahId: string
  allowQuickAdd?: boolean
  title?: string
}) {
  const [items, setItems] = useState<SurveyItem[]>([])
  const [note, setNote] = useState(\"\")
  const [isLoading, setIsLoading] = useState(true)
  const [isSubmitting, setIsSubmitting] = useState(false)
  const [errorMessage, setErrorMessage] = useState<string | null>(null)

  const endpoint = useMemo(() => "'`/api/nasabah/${nasabahId}/survey`, [nasabahId])

  const loadSurvey = useCallback(async () => {
    setIsLoading(true)
    setErrorMessage(null)

    try {
      const res = await fetch(endpoint, { method: "GET", cache: "no-store" })
      const json = (await res.json().catch(() => ({}))) as SurveyResponse

      if (!res.ok) {
        throw new Error(json.error ?? "Gagal memuat timeline survey.")
      }

      setItems(Array.isArray(json.items) ? json.items : [])
    } catch (error) {
      const message = error instanceof Error ? error.message : "Gagal memuat timeline survey."
      setErrorMessage(message)
    } finally {
      setIsLoading(false)
    }
  }, [endpoint])

  useEffect(() => {
    void loadSurvey()
  }, [loadSurvey])

  async function handleAddNote(e: React.FormEvent<HTMLFormElement>) {
    e.preventDefault()
    const trimmed = note.trim()
    if (!trimmed) {
      toast.error("Catatan survei tidak boleh kosong.")
      return
    }

    setIsSubmitting(true)
    try {
      const res = await fetch(endpoint, {
        method: "POST",
        headers: { "Content-Type": "application/json" },
        body: JSON.stringify({ note: trimmed }),
      })
      const json = (await res.json().catch(() => ({}))) as SurveyResponse

      if (!res.ok) {
        throw new Error(json.error ?? "Gagal menambahkan catatan survey.")
      }

      if (json.item) {
        setItems((prev) => {
          const withoutDup = prev.filter((item) => item.id !== json.item?.id)
          return [json.item as SurveyItem, ...withoutDup]
        })
      } else {
        await loadSurvey()
      }

      setNote("")
      toast.success(json.message ?? "Catatan survey berhasil ditambahkan.")
    } catch (error) {
      const message = error instanceof Error ? error.message : "Gagal menambahkan catatan survey."
      toast.error(message)
    } finally {
      setIsSubmitting(false)
    }
  }

  return (
    <Card>
      <CardHeader className="flex flex-row items-center justify-between gap-3">
        <CardTitle className="text-base">{title}</CardTitle>
        <Button type="button" variant="outline" size="sm" onClick={() => void loadSurvey()} disabled={isLoading || isSubmitting}>
          {isLoading ? <Loader2 className="size-4 animate-spin" /> : <RefreshCw className="size-4" />}
          Muat Ulang
        </Button>
      </CardHeader>
      <CardContent className="space-y-4">
        {allowQuickAdd ? (
          <form onSubmit={handleAddNote} className="space-y-2 rounded-md border p-3">
            <p className="text-xs font-medium text-muted-foreground">Quick Add Catatan Survey</p>
            <Textarea
              value={note}
              onChange={(e) => setNote(e.target.value)}
              placeholder="Contoh: Hasil kunjungan lapangan hari ini..."
              rows={3}
              maxLength={1000}
              disabled={isSubmitting}
            />
            <div className="flex items-center justify-between gap-3">
              <p className="text-xs text-muted-foreground">{note.length}/1000 karakter</p>
              <Button type="submit" size="sm" disabled={isSubmitting || !note.trim()}>
                {isSubmitting ? <Loader2 className="size-4 animate-spin" /> : <Plus className="size-4" />}
                {isSubmitting ? "Menyimpan..." : "Tambah Catatan"}
              </Button>
            </div>
          </form>
        ) : null}

        {isLoading ? (
          <div className="flex items-center gap-2 rounded-md border border-dashed p-3 text-sm text-muted-foreground">
            <Loader2 className="size-4 animate-spin" /> Memuat timeline survey...
          </div>
        ) : errorMessage ? (
          <div className="rounded-md border border-red-200 bg-red-50 p-3 text-sm text-red-700">
            <div className="flex items-start gap-2">
              <AlertCircle className="mt-0.5 size-4" />
              <div>
                <p className="font-medium">Gagal memuat data survey</p>
                <p className="text-xs">{errorMessage}</p>
              </div>
            </div>
          </div>
        ) : items.length === 0 ? (
          <p className="text-sm text-muted-foreground">Belum ada catatan survey.</p>
        ) : (
          <div className="space-y-3">
            {items.map((item) => (
              <div key={item.id} className="rounded-md border p-3">
                <div className="flex flex-wrap items-center gap-2 text-xs">
                  <Badge className={statusClass[item.status] ?? "bg-slate-100 text-slate-700"}>{item.status}</Badge>
                  <span className="text-muted-foreground">{fmtDateTime(item.createdAt)}</span>
                  <span className="text-muted-foreground">•</span>
                  <span className="text-muted-foreground">{item.surveyorName ?? "Petugas tidak tercatat"}</span>
                </div>
                <p className="mt-2 whitespace-pre-wrap text-sm leading-6">{item.note}</p>
              </div>
            ))}
          </div>
        )}
      </CardContent>
    </Card>
  )
}
