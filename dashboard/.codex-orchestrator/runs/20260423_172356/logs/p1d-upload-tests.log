import assert from \"node:assert/strict\"
import test from \"node:test\"
import { createNasabahUploadHandler } from \"../route\"

const FIVE_MB = 5 * 1024 * 1024

function createRequest(files: File[] = []) {
  const formData = new FormData()
  for (const file of files) {
    formData.append(\"files\", file)
  }
  return new Request(\"http://localhost/api/upload/nasabah\", {
    method: \"POST\",
    body: formData,
  })
}

test(\"returns 401 when unauthorized\", async () => {
  let uploadCalled = false
  const handler = createNasabahUploadHandler({
    auth: async () => null,
    uploadFilesToBlob: async () => {
      uploadCalled = true
      return [\"https://blob.example/doc-1.pdf\"]
    },
  })

  const res = await handler(createRequest())
  const json = (await res.json()) as { error: string }

  assert.equal(res.status, 401)
  assert.deepEqual(json, { error: \"Unauthorized\" })
  assert.equal(uploadCalled, false)
})

test(\"returns 400 when no files provided\", async () => {
  let uploadCalled = false
  const handler = createNasabahUploadHandler({
    auth: async () => ({ user: { companyId: \"cmp-01\" } }),
    uploadFilesToBlob: async () => {
      uploadCalled = true
      return [\"https://blob.example/doc-1.pdf\"]
    },
  })

  const res = await handler(createRequest())
  const json = (await res.json()) as { error: string }

  assert.equal(res.status, 400)
  assert.deepEqual(json, { error: \"Tidak ada file yang diupload.\" })
  assert.equal(uploadCalled, false)
})

test(\"returns 400 when file mime type is invalid\", async () => {
  let uploadCalled = false
  const handler = createNasabahUploadHandler({
    auth: async () => ({ user: { companyId: \"cmp-01\" } }),
    uploadFilesToBlob: async () => {
      uploadCalled = true
      return [\"https://blob.example/doc-1.pdf\"]
    },
  })

  const invalidFile = new File([\"hello\"], \"catatan.txt\", { type: \"text/plain\" })

  const res = await handler(createRequest([invalidFile]))
  const json = (await res.json()) as { error: string }

  assert.equal(res.status, 400)
  assert.equal(json.error, \"Tipe file tidak didukung: catatan.txt\")
  assert.equal(uploadCalled, false)
})

test(\"returns 400 when file count exceeds maximum\", async () => {
  let uploadCalled = false
  const handler = createNasabahUploadHandler({
    auth: async () => ({ user: { companyId: \"cmp-01\" } }),
    uploadFilesToBlob: async () => {
      uploadCalled = true
      return [\"https://blob.example/doc-1.pdf\"]
    },
  })

  const files = Array.from({ length: 11 }, (_, i) => {
    return new File(["'`img-${i}`], `dokumen-${i}.png`, { type: "image/png" })
  })

  const res = await handler(createRequest(files))
  const json = (await res.json()) as { error: string }

  assert.equal(res.status, 400)
  assert.equal(json.error, "Maksimal 10 file per upload.")
  assert.equal(uploadCalled, false)
})

test("returns 400 when file is too large", async () => {
  let uploadCalled = false
  const handler = createNasabahUploadHandler({
    auth: async () => ({ user: { companyId: "cmp-01" } }),
    uploadFilesToBlob: async () => {
      uploadCalled = true
      return ["https://blob.example/doc-1.pdf"]
    },
  })

  const tooLargeFile = new File([new Uint8Array(FIVE_MB + 1)], "ktp.pdf", {
    type: "application/pdf",
  })

  const res = await handler(createRequest([tooLargeFile]))
  const json = (await res.json()) as { error: string }

  assert.equal(res.status, 400)
  assert.equal(json.error, "Ukuran file melebihi 5 MB: ktp.pdf")
  assert.equal(uploadCalled, false)
})

test("returns urls and uses tenant-aware upload path on success", async () => {
  let capturedFolder = ""
  let capturedFilesLength = 0

  const handler = createNasabahUploadHandler({
    auth: async () => ({ user: { companyId: "cmp-tenant-123" } }),
    uploadFilesToBlob: async (files, folder) => {
      capturedFilesLength = files.length
      capturedFolder = folder
      return ["https://blob.example/1.pdf", "https://blob.example/2.png"]
    },
  })

  const validFiles = [
    new File(["one"], "ktp.pdf", { type: "application/pdf" }),
    new File(["two"], "kk.png", { type: "image/png" }),
  ]

  const res = await handler(createRequest(validFiles))
  const json = (await res.json()) as { urls: string[] }

  assert.equal(res.status, 200)
  assert.deepEqual(json, { urls: ["https://blob.example/1.pdf", "https://blob.example/2.png"] })
  assert.equal(capturedFilesLength, 2)
  assert.equal(capturedFolder, "uploads/cmp-tenant-123/nasabah")
})
