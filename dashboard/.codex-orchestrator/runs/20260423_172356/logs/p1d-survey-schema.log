  nasabah   Nasabah  @relation(fields: [nasabahId], references: [id])

  @@index([companyId])
  @@map("simpanan")
}

model Account {
  id           String            @id @default(cuid())
  code         String
  name         String
  type         AccountType
  isActive     Boolean           @default(true)
  createdAt    DateTime          @default(now())
  updatedAt    DateTime          @updatedAt
  companyId    String
  company      Company           @relation(fields: [companyId], references: [id], onDelete: Cascade)
  journalLines JournalLine[]
  kasKategori  KasKategori[]
  rekonsiliasi RekonsiliasiKas[]

  @@unique([companyId, code])
  @@index([type, isActive])
  @@index([companyId])
  @@map("accounts")
}

model JournalEntry {
  id          String            @id @default(cuid())
  entryNo     String            @unique @default(cuid())
  entryDate   DateTime
  description String
  sourceType  JournalSourceType
  sourceId    String?
  status      JournalStatus     @default(POSTED)
  postedById  String?
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt
  companyId   String
  company     Company           @relation(fields: [companyId], references: [id], onDelete: Cascade)
  postedBy    User?             @relation("JournalPostedBy", fields: [postedById], references: [id])
  lines       JournalLine[]

  @@unique([sourceType, sourceId])
  @@index([entryDate])
  @@index([sourceType, sourceId])
  @@index([companyId])
  @@map("journal_entries")
}

model JournalLine {
  id             String       @id @default(cuid())
  journalEntryId String
