+async function generateNomorAnggotaTx(tx: Prisma.TransactionClient, companyId: string, now: Date = new Date()): Promise<string> {
+  const yearSuffix = now.getFullYear().toString().slice(2)
+  const lockKey = Number(yearSuffix)
+  const regex = `^N-${yearSuffix}-([0-9]+)$`
+
+  // Serialize sequence generation per company+year to avoid duplicate nomorAnggota on concurrent creates.
+  await tx.$executeRaw`SELECT pg_advisory_xact_lock(hashtext(${companyId}), ${lockKey})`
+  const rows = await tx.$queryRaw<Array<{ maxSeq: number }>>`
+    SELECT COALESCE(MAX((regexp_match("nomorAnggota", ${regex}))[1]::int), 0) AS "maxSeq"
+    FROM "Nasabah"
+    WHERE "companyId" = ${companyId}
+  `
+
+  const nextSeq = (rows[0]?.maxSeq ?? 0) + 1
+  return `N-${yearSuffix}-${String(nextSeq).padStart(4, "0")}`
 }
 
