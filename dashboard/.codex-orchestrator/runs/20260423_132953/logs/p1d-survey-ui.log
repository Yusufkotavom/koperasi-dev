@@ -0,0 +1,121 @@
+"use client"
+
+import { useCallback, useEffect, useState } from "react"
+import { Plus } from "lucide-react"
+import { toast } from "sonner"
+import { Card, CardContent, CardHeader, CardTitle } from "@/components/ui/card"
+import { Button } from "@/components/ui/button"
+import { Textarea } from "@/components/ui/textarea"
+import { Alert, AlertDescription } from "@/components/ui/alert"
+import { Skeleton } from "@/components/ui/skeleton"
+import { formatDateTimeId } from "@/lib/datetime"
+import { createSurveyNote, fetchSurveyTimeline, type SurveyTimelineItem } from "./survey-client"
+
+export function SurveyQuickNoteCard({ nasabahId }: { nasabahId: string }) {
+  const [note, setNote] = useState("")
+  const [items, setItems] = useState<SurveyTimelineItem[]>([])
+  const [isLoading, setIsLoading] = useState(true)
+  const [isSubmitting, setIsSubmitting] = useState(false)
+  const [error, setError] = useState<string | null>(null)
+
+  const loadLatest = useCallback(async (signal?: AbortSignal) => {
+    setError(null)
+    setIsLoading(true)
+    try {
+      const timeline = await fetchSurveyTimeline(nasabahId, signal)
+      setItems(timeline.slice(0, 5))
+    } catch (err) {
+      if (signal?.aborted) return
+      setError(err instanceof Error ? err.message : "Gagal memuat catatan survey.")
+    } finally {
+      if (!signal?.aborted) setIsLoading(false)
+    }
+  }, [nasabahId])
+
+  useEffect(() => {
+    const controller = new AbortController()
+    void loadLatest(controller.signal)
+    return () => controller.abort()
+  }, [loadLatest])
+
+  async function handleSubmit(event: React.FormEvent<HTMLFormElement>) {
+    event.preventDefault()
+    const clean = note.trim()
+    if (!clean) {
+      setError("Catatan survey wajib diisi.")
+      return
+    }
+
+    setIsSubmitting(true)
+    setError(null)
+    try {
+      await createSurveyNote(nasabahId, clean)
+      setNote("")
+      await loadLatest()
+      toast.success("Catatan survey ditambahkan.")
+    } catch (err) {
+      const message = err instanceof Error ? err.message : "Gagal menambahkan catatan survey."
+      setError(message)
+      toast.error(message)
+    } finally {
+      setIsSubmitting(false)
+    }
+  }
+
+  return (
+    <Card>
+      <CardHeader>
+        <CardTitle className="text-base">Quick Add Catatan Survey</CardTitle>
+      </CardHeader>
+      <CardContent className="space-y-4">
+        <form className="space-y-2" onSubmit={handleSubmit}>
+          <Textarea
+            rows={3}
+            placeholder="Tulis hasil observasi atau tindak lanjut survey..."
+            value={note}
+            onChange={(event) => setNote(event.target.value)}
+            disabled={isSubmitting}
+          />
+          <Button type="submit" className="bg-emerald-600 hover:bg-emerald-700" disabled={isSubmitting}>
+            <Plus className="size-4" />
+            {isSubmitting ? "Menyimpan..." : "Tambah Catatan Survey"}
+          </Button>
+        </form>
+
+        {error ? (
+          <Alert variant="destructive">
+            <AlertDescription>{error}</AlertDescription>
+          </Alert>
+        ) : null}
+
+        <div className="space-y-2">
+          <p className="text-xs font-medium text-muted-foreground">Catatan terakhir</p>
+          {isLoading ? (
+            <div className="space-y-2">
+              <Skeleton className="h-12 w-full" />
+              <Skeleton className="h-12 w-full" />
+            </div>
+          ) : null}
+
+          {!isLoading && items.length === 0 ? (
+            <p className="text-sm text-muted-foreground">Belum ada catatan survey.</p>
+          ) : null}
+
+          {!isLoading && items.length > 0 ? (
+            <div className="space-y-2">
+              {items.map((item) => (
+                <div key={item.id} className="rounded-md border p-2.5">
+                  <p className="text-sm leading-relaxed whitespace-pre-wrap">{item.note}</p>
+                  <p className="mt-1 text-xs text-muted-foreground">
+                    {formatDateTimeId(item.createdAt)}
+                    {item.createdByName ? ` · ${item.createdByName}` : ""}
+                  </p>
+                </div>
+              ))}
+            </div>
+          ) : null}
+        </div>
+      </CardContent>
+    </Card>
+  )
+}
