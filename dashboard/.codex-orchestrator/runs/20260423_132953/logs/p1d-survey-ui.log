+"use client"
+
+import { useCallback, useEffect, useState } from "react"
+import { RefreshCw } from "lucide-react"
+import { Card, CardContent, CardHeader, CardTitle } from "@/components/ui/card"
+import { Button } from "@/components/ui/button"
+import { Alert, AlertDescription, AlertTitle } from "@/components/ui/alert"
+import { Skeleton } from "@/components/ui/skeleton"
+import { formatDateTimeId } from "@/lib/datetime"
+import { fetchSurveyTimeline, type SurveyTimelineItem } from "./survey-client"
+
+export function SurveyTimelineCard({ nasabahId }: { nasabahId: string }) {
+  const [items, setItems] = useState<SurveyTimelineItem[]>([])
+  const [isLoading, setIsLoading] = useState(true)
+  const [error, setError] = useState<string | null>(null)
+
+  const loadTimeline = useCallback(async (signal?: AbortSignal) => {
+    setError(null)
+    setIsLoading(true)
+    try {
+      const next = await fetchSurveyTimeline(nasabahId, signal)
+      setItems(next)
+    } catch (err) {
+      if (signal?.aborted) return
+      setError(err instanceof Error ? err.message : "Gagal memuat timeline survey.")
+    } finally {
+      if (!signal?.aborted) setIsLoading(false)
+    }
+  }, [nasabahId])
+
+  useEffect(() => {
+    const controller = new AbortController()
+    void loadTimeline(controller.signal)
+    return () => controller.abort()
+  }, [loadTimeline])
+
+  return (
+    <Card id="survey" className="scroll-mt-24">
+      <CardHeader className="flex flex-row items-center justify-between">
+        <CardTitle className="text-base">Timeline Survey</CardTitle>
+        <Button
+          type="button"
+          variant="outline"
+          size="sm"
+          onClick={() => void loadTimeline()}
+          disabled={isLoading}
+        >
+          <RefreshCw className={`size-3.5 ${isLoading ? "animate-spin" : ""}`} />
+          Muat Ulang
+        </Button>
+      </CardHeader>
+      <CardContent className="space-y-3">
+        {isLoading ? (
+          <div className="space-y-3">
+            <Skeleton className="h-14 w-full" />
+            <Skeleton className="h-14 w-full" />
+            <Skeleton className="h-14 w-full" />
+          </div>
+        ) : null}
+
+        {!isLoading && error ? (
+          <Alert variant="destructive">
+            <AlertTitle>Timeline survey belum tersedia</AlertTitle>
+            <AlertDescription>{error}</AlertDescription>
+          </Alert>
+        ) : null}
+
+        {!isLoading && !error && items.length === 0 ? (
+          <p className="text-sm text-muted-foreground">Belum ada catatan survey untuk nasabah ini.</p>
+        ) : null}
+
+        {!isLoading && !error && items.length > 0 ? (
+          <div className="space-y-4">
+            {items.map((item, index) => (
+              <div key={item.id} className="relative pl-6">
+                <span className="absolute left-0 top-1 size-2.5 rounded-full bg-emerald-600" />
+                {index < items.length - 1 ? <span className="absolute left-[4px] top-4 h-[calc(100%+8px)] w-px bg-border" /> : null}
+                <div className="space-y-1">
+                  <p className="text-sm leading-relaxed whitespace-pre-wrap">{item.note}</p>
+                  <p className="text-xs text-muted-foreground">
+                    {formatDateTimeId(item.createdAt)}
+                    {item.createdByName ? ` · ${item.createdByName}` : ""}
+                    {item.status ? ` · ${item.status}` : ""}
+                  </p>
+                </div>
+              </div>
+            ))}
+          </div>
+        ) : null}
+      </CardContent>
+    </Card>
+  )
+}
