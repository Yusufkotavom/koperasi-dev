diff --git a/dashboard/src/app/(dashboard)/nasabah/[id]/edit/survey-client.ts b/dashboard/src/app/(dashboard)/nasabah/[id]/edit/survey-client.ts
new file mode 100644
index 0000000000000000000000000000000000000000..c557aa78e396649a3a8f3a84cb98e4cd9a4cbcf5
--- /dev/null
+++ b/dashboard/src/app/(dashboard)/nasabah/[id]/edit/survey-client.ts
@@ -0,0 +1,118 @@
+"use client"
+
+export type SurveyTimelineItem = {
+  id: string
+  note: string
+  createdAt: string | null
+  createdByName: string | null
+  status: string | null
+}
+
+function asRecord(value: unknown): Record<string, unknown> | null {
+  if (!value || typeof value !== "object" || Array.isArray(value)) return null
+  return value as Record<string, unknown>
+}
+
+function firstString(record: Record<string, unknown>, keys: string[]): string | null {
+  for (const key of keys) {
+    const raw = record[key]
+    if (typeof raw === "string" && raw.trim()) return raw.trim()
+  }
+  return null
+}
+
+function pickArray(payload: unknown): unknown[] {
+  if (Array.isArray(payload)) return payload
+  const data = asRecord(payload)
+  if (!data) return []
+  const candidates = [data.data, data.items, data.timeline, data.survey, data.surveys]
+  for (const candidate of candidates) {
+    if (Array.isArray(candidate)) return candidate
+  }
+  return []
+}
+
+function parseSurveyItem(item: unknown, idx: number): SurveyTimelineItem | null {
+  const record = asRecord(item)
+  if (!record) return null
+
+  const createdByRaw = asRecord(record.createdBy) ?? asRecord(record.user) ?? asRecord(record.petugas)
+  const createdByName = createdByRaw
+    ? firstString(createdByRaw, ["name", "nama", "fullName"])
+    : firstString(record, ["createdByName", "userName", "petugasName"])
+
+  const note = firstString(record, ["note", "catatan", "isi", "text", "keterangan", "description"])
+  if (!note) return null
+
+  const id =
+    firstString(record, ["id", "uuid", "surveyId"]) ??
+    `${firstString(record, ["createdAt", "created_at", "tanggal", "timestamp"]) ?? "survey"}-${idx}`
+
+  return {
+    id,
+    note,
+    createdAt: firstString(record, ["createdAt", "created_at", "tanggal", "timestamp", "waktu"]),
+    createdByName,
+    status: firstString(record, ["status", "type", "kategori", "event"]),
+  }
+}
+
+export function normalizeSurveyTimeline(payload: unknown): SurveyTimelineItem[] {
+  return pickArray(payload)
+    .map(parseSurveyItem)
+    .filter((item): item is SurveyTimelineItem => Boolean(item))
+    .sort((a, b) => {
+      if (!a.createdAt && !b.createdAt) return 0
+      if (!a.createdAt) return 1
+      if (!b.createdAt) return -1
+      return new Date(b.createdAt).getTime() - new Date(a.createdAt).getTime()
+    })
+}
+
+function extractErrorMessage(payload: unknown): string | null {
+  const record = asRecord(payload)
+  if (!record) return null
+  const direct = firstString(record, ["error", "message", "detail"])
+  if (direct) return direct
+  const nestedError = asRecord(record.error)
+  return nestedError ? firstString(nestedError, ["message", "detail"]) : null
+}
+
+async function readJson(res: Response): Promise<unknown> {
+  try {
+    return await res.json()
+  } catch {
+    return null
+  }
+}
+
+export async function fetchSurveyTimeline(nasabahId: string, signal?: AbortSignal): Promise<SurveyTimelineItem[]> {
+  const res = await fetch(`/api/nasabah/${nasabahId}/survey`, {
+    method: "GET",
+    headers: { accept: "application/json" },
+    cache: "no-store",
+    signal,
+  })
+  const payload = await readJson(res)
+  if (!res.ok) {
+    throw new Error(extractErrorMessage(payload) ?? "Gagal memuat riwayat survey.")
+  }
+  return normalizeSurveyTimeline(payload)
+}
+
+export async function createSurveyNote(nasabahId: string, note: string): Promise<void> {
+  const res = await fetch(`/api/nasabah/${nasabahId}/survey`, {
+    method: "POST",
+    headers: { "content-type": "application/json", accept: "application/json" },
+    body: JSON.stringify({
+      note,
+      catatan: note,
+      text: note,
+    }),
+    cache: "no-store",
+  })
+  const payload = await readJson(res)
+  if (!res.ok) {
+    throw new Error(extractErrorMessage(payload) ?? "Gagal menambahkan catatan survey.")
+  }
+}
