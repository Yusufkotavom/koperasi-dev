+    if (!session) {
+      return Response.json({ error: "Unauthorized" }, { status: 401 })
+    }
+
+    const folder = getTenantUploadFolder(session)
+    if (!folder) {
+      return Response.json({ error: "Akun belum terhubung ke company." }, { status: 400 })
+    }
+
+    const formData = await req.formData()
+    const files = formData.getAll("files").filter((v): v is File => v instanceof File)
+    const validationError = validateFiles(files)
+
+    if (validationError) {
+      return Response.json({ error: validationError }, { status: 400 })
+    }
+
+    try {
+      const uploadedUrls = await deps.uploadFn(files, folder)
+      return Response.json({ urls: uploadedUrls })
+    } catch (error) {
+      const message = error instanceof Error ? error.message : "Upload dokumen gagal."
+      return Response.json({ error: message }, { status: 400 })
+    }
   }
 }
+
+export const POST = createPostHandler()

