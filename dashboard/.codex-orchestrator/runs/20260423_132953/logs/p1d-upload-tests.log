+import test from "node:test"
+import assert from "node:assert/strict"
+import {
+  createPostHandler,
+  NASABAH_MAX_FILE_COUNT,
+  NASABAH_MAX_FILE_SIZE,
+} from "../route"
+
+function makeRequest(files: File[] = []) {
+  const formData = new FormData()
+  for (const file of files) formData.append("files", file)
+  return new Request("http://localhost/api/upload/nasabah", {
+    method: "POST",
+    body: formData,
+  })
+}
+
+test("returns 401 when unauthorized", async () => {
+  const handler = createPostHandler({
+    authFn: async () => null,
+    uploadFn: async () => {
+      throw new Error("should not be called")
+    },
+  })
+
+  const res = await handler(makeRequest([new File(["ok"], "ok.pdf", { type: "application/pdf" })]))
+  const json = (await res.json()) as { error?: string }
+
+  assert.equal(res.status, 401)
+  assert.equal(json.error, "Unauthorized")
+})
+
+test("returns 400 when no files uploaded", async () => {
+  let called = false
+  const handler = createPostHandler({
+    authFn: async () => ({ user: { companyId: "tenant-a" } }),
+    uploadFn: async () => {
+      called = true
+      return []
+    },
+  })
+
+  const res = await handler(makeRequest())
+  const json = (await res.json()) as { error?: string }
+
+  assert.equal(res.status, 400)
+  assert.equal(json.error, "Tidak ada file yang diupload.")
+  assert.equal(called, false)
+})
+
+test("returns 400 when file mime type is invalid", async () => {
+  let called = false
+  const handler = createPostHandler({
+    authFn: async () => ({ user: { companyId: "tenant-a" } }),
+    uploadFn: async () => {
+      called = true
+      return []
+    },
+  })
+
+  const res = await handler(makeRequest([new File(["bad"], "notes.txt", { type: "text/plain" })]))
+  const json = (await res.json()) as { error?: string }
+
+  assert.equal(res.status, 400)
+  assert.equal(json.error, "Tipe file tidak didukung: notes.txt")
+  assert.equal(called, false)
+})
+
+test("returns 400 when file count exceeds maximum", async () => {
+  let called = false
+  const handler = createPostHandler({
+    authFn: async () => ({ user: { companyId: "tenant-a" } }),
+    uploadFn: async () => {
+      called = true
+      return []
+    },
+  })
+
+  const files = Array.from({ length: NASABAH_MAX_FILE_COUNT + 1 }, (_, i) =>
+    new File([`file-${i}`], `f-${i}.pdf`, { type: "application/pdf" }),
+  )
+  const res = await handler(makeRequest(files))
+  const json = (await res.json()) as { error?: string }
+
+  assert.equal(res.status, 400)
+  assert.equal(json.error, `Maksimal ${NASABAH_MAX_FILE_COUNT} file per upload.`)
+  assert.equal(called, false)
+})
+
+test("returns 400 when file size exceeds maximum", async () => {
+  let called = false
+  const handler = createPostHandler({
+    authFn: async () => ({ user: { companyId: "tenant-a" } }),
+    uploadFn: async () => {
+      called = true
+      return []
+    },
+  })
+
+  const oversized = new File([new Uint8Array(NASABAH_MAX_FILE_SIZE + 1)], "big.pdf", {
+    type: "application/pdf",
+  })
+  const res = await handler(makeRequest([oversized]))
+  const json = (await res.json()) as { error?: string }
+
+  assert.equal(res.status, 400)
+  assert.equal(json.error, "Ukuran file melebihi 5 MB: big.pdf")
+  assert.equal(called, false)
+})
+
+test("returns urls on successful upload and uses tenant-aware folder", async () => {
+  let folderArg = ""
+  let filesArgLength = 0
+
+  const handler = createPostHandler({
+    authFn: async () => ({ user: { companyId: "tenant_01" } }),
+    uploadFn: async (files, folder) => {
+      folderArg = folder
+      filesArgLength = files.length
+      return ["https://blob.test/file-1.pdf"]
+    },
+  })
+
+  const file = new File(["ok"], "ok.pdf", { type: "application/pdf" })
+  const res = await handler(makeRequest([file]))
+  const json = (await res.json()) as { urls?: string[] }
+
+  assert.equal(res.status, 200)
+  assert.deepEqual(json.urls, ["https://blob.test/file-1.pdf"])
+  assert.equal(folderArg, "uploads/tenant_01/nasabah")
+  assert.equal(filesArgLength, 1)
+})
