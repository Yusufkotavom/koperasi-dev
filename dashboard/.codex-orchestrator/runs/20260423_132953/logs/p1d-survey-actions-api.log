import {
  createNasabahSurveyNote,
  isSurveyActionError,
  listNasabahSurveyNotes,
} from \"@/actions/nasabah-survey\"

function successResponse(data: unknown, status = 200) {
  return Response.json({ success: true, data }, { status })
}

function errorResponse(status: number, code: string, message: string) {
  return Response.json(
    {
      success: false,
      error: { code, message },
    },
    { status },
  )
}

function mapUnknownError(error: unknown) {
  if (isSurveyActionError(error)) {
    return errorResponse(error.status, error.code, error.message)
  }

  if (error instanceof Error) {
    if (error.message === \"Unauthorized\") {
      return errorResponse(401, \"UNAUTHORIZED\", \"Unauthorized\")
    }
    if (error.message === \"Forbidden\") {
      return errorResponse(403, \"FORBIDDEN\", \"Akses ditolak.\")
    }
    if (error.message === \"Akun belum terhubung ke company.\" || error.message === \"Company context required\") {
      return errorResponse(400, \"COMPANY_CONTEXT_REQUIRED\", error.message)
    }
  }

  return errorResponse(500, \"INTERNAL_SERVER_ERROR\", \"Terjadi kesalahan pada server.\")
}

export async function GET(_: Request, context: { params: Promise<{ id: string }> }) {
  try {
    const { id } = await context.params
    const result = await listNasabahSurveyNotes(id)
    return successResponse(result)
  } catch (error) {
    return mapUnknownError(error)
  }
}

export async function POST(req: Request, context: { params: Promise<{ id: string }> }) {
  let payload: unknown

  try {
    payload = await req.json()
  } catch {
    return errorResponse(400, \"INVALID_JSON\", \"Body JSON tidak valid.\")
  }

  try {
    const { id } = await context.params
    const result = await createNasabahSurveyNote(id, payload)
    return successResponse(result, 201)
  } catch (error) {
    return mapUnknownError(error)
  }
}
