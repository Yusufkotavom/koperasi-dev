\"use server\"

import { auth } from \"@/lib/auth\"
import { prisma } from \"@/lib/prisma\"
import { requireRoles } from \"@/lib/roles\"
import { requireCompanyId } from \"@/lib/tenant\"
import { RoleType } from \"@prisma/client\"
import { z } from \"zod\"

type SessionLike = {
  user?: {
    id?: string
    roles?: string[]
    companyId?: string | null
  }
} | null

const ALLOWED_SURVEY_ROLES: RoleType[] = [
  RoleType.SURVEYOR,
  RoleType.ADMIN,
  RoleType.MANAGER,
  RoleType.PIMPINAN,
  RoleType.OWNER,
  RoleType.SUPER_ADMIN,
]

const createSurveyNoteSchema = z.object({
  note: z
    .string({ error: \"Catatan survey wajib diisi.\" })
    .trim()
    .min(1, \"Catatan survey wajib diisi.\")
    .max(2000, \"Catatan survey maksimal 2000 karakter.\"),
})

const storedSurveyNoteSchema = z.object({
  id: z.string().min(1),
  note: z.string().min(1),
  createdAt: z.string().datetime(),
  createdById: z.string().min(1),
})

type StoredSurveyNote = z.infer<typeof storedSurveyNoteSchema>

type SurveyNote = {
  id: string
  note: string
  createdAt: string
  createdById: string | null
  pengajuanId: string
}

export class SurveyActionError extends Error {
  status: number
  code: string

  constructor(status: number, code: string, message: string) {
    super(message)
    this.status = status
    this.code = code
    this.name = \"SurveyActionError\"
  }
}

export function isSurveyActionError(error: unknown): error is SurveyActionError {
  return error instanceof SurveyActionError
}

function requireSurveyContext(session: SessionLike) {
  requireRoles(session, ALLOWED_SURVEY_ROLES)
  return requireCompanyId(session)
}

function parseStoredNotes(raw: string | null | undefined): StoredSurveyNote[] {
  const value = raw?.trim()
  if ("'!value) return []

  try {
    const parsed = JSON.parse(value) as unknown

    if (Array.isArray(parsed)) {
      return parsed
        .map((entry) => storedSurveyNoteSchema.safeParse(entry))
        .filter((result): result is { success: true; data: StoredSurveyNote } => result.success)
        .map((result) => result.data)
    }

    const withNotes = z.object({ notes: z.array(storedSurveyNoteSchema) }).safeParse(parsed)
    if (withNotes.success) return withNotes.data.notes
  } catch {
    return []
  }

  return []
}

function mapLegacySurveyText(raw: string | null | undefined, context: { pengajuanId: string; fallbackAt: Date }): SurveyNote[] {
  const text = raw?.trim()
  if (!text) return []

  const parsedNotes = parseStoredNotes(text)
  if (parsedNotes.length > 0) {
    return parsedNotes.map((note) => ({
      ...note,
      createdById: note.createdById,
      pengajuanId: context.pengajuanId,
    }))
  }

  return [
    {
      id: `legacy-${context.pengajuanId}`,
      note: text,
      createdAt: context.fallbackAt.toISOString(),
      createdById: null,
      pengajuanId: context.pengajuanId,
    },
  ]
}

export async function listNasabahSurveyNotes(nasabahId: string): Promise<{ notes: SurveyNote[] }> {
  const session = await auth()
  const { companyId } = requireSurveyContext(session as SessionLike)

  const nasabah = await prisma.nasabah.findFirst({
    where: { id: nasabahId, companyId },
    select: { id: true },
  })

  if (!nasabah) {
    throw new SurveyActionError(404, "NASABAH_NOT_FOUND", "Nasabah tidak ditemukan.")
  }

  const pengajuanList = await prisma.pengajuan.findMany({
    where: { nasabahId, companyId },
    select: {
      id: true,
      hasilSurvey: true,
      tanggalSurvey: true,
      updatedAt: true,
    },
    orderBy: [{ updatedAt: "desc" }, { tanggalPengajuan: "desc" }],
  })

  const notes = pengajuanList
    .flatMap((pengajuan) =>
      mapLegacySurveyText(pengajuan.hasilSurvey, {
        pengajuanId: pengajuan.id,
        fallbackAt: pengajuan.tanggalSurvey ?? pengajuan.updatedAt,
      }),
    )
    .sort((a, b) => b.createdAt.localeCompare(a.createdAt))

  return { notes }
}

export async function createNasabahSurveyNote(
  nasabahId: string,
  input: unknown,
): Promise<{ note: SurveyNote; totalNotes: number }> {
  const session = await auth()
  const { userId, companyId } = requireSurveyContext(session as SessionLike)

  const parsed = createSurveyNoteSchema.safeParse(input)
  if (!parsed.success) {
    const issue = parsed.error.issues[0]
    throw new SurveyActionError(400, "INVALID_NOTE", issue?.message ?? "Input catatan survey tidak valid.")
  }

  const nasabah = await prisma.nasabah.findFirst({
    where: { id: nasabahId, companyId },
    select: { id: true },
  })

  if (!nasabah) {
    throw new SurveyActionError(404, "NASABAH_NOT_FOUND", "Nasabah tidak ditemukan.")
  }

  const latestPengajuan = await prisma.pengajuan.findFirst({
    where: { nasabahId, companyId },
    orderBy: [{ tanggalPengajuan: "desc" }, { createdAt: "desc" }],
    select: {
      id: true,
      hasilSurvey: true,
      tanggalSurvey: true,
      updatedAt: true,
    },
  })

  if (!latestPengajuan) {
    throw new SurveyActionError(404, "PENGAJUAN_NOT_FOUND", "Pengajuan untuk nasabah ini belum tersedia.")
  }

  const existingNotes = mapLegacySurveyText(latestPengajuan.hasilSurvey, {
    pengajuanId: latestPengajuan.id,
    fallbackAt: latestPengajuan.tanggalSurvey ?? latestPengajuan.updatedAt,
  })

  const createdAt = new Date().toISOString()
  const note: SurveyNote = {
    id: crypto.randomUUID(),
    note: parsed.data.note,
    createdAt,
    createdById: userId,
    pengajuanId: latestPengajuan.id,
  }

  const nextStoredNotes: StoredSurveyNote[] = [
    ...existingNotes.map((entry) => ({
      id: entry.id,
      note: entry.note,
      createdAt: entry.createdAt,
      createdById: entry.createdById ?? "legacy",
    })),
    {
      id: note.id,
      note: note.note,
      createdAt: note.createdAt,
      createdById: userId,
    },
  ]

  await prisma.pengajuan.update({
    where: { id: latestPengajuan.id },
    data: {
      hasilSurvey: JSON.stringify({ notes: nextStoredNotes }),
      tanggalSurvey: new Date(),
      surveyorId: userId,
    },
  })

  return {
    note,
    totalNotes: nextStoredNotes.length,
  }
}
