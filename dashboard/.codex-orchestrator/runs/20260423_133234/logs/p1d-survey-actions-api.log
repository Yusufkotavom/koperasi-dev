  company           Company          @relation(fields: [companyId], references: [id], onDelete: Cascade)
  pengajuan         Pengajuan        @relation(fields: [pengajuanId], references: [id])

  @@index([companyId])
  @@map("pinjaman")
}

model JadwalAngsuran {
  id                String    @id @default(cuid())
  pinjamanId        String
