    roles: ["OWNER", "ADMIN"],
  })

  const company = await prisma.company.create({
    data: {
      name: "Koperasi Demo Sejahtera",
      slug: "koperasi-demo-sejahtera",
      email: "admin@koperasi.id",
      ownerId: admin.id,
    },
  })

  await prisma.user.update({
    where: { id: admin.id },
    data: { companyId: company.id },
  })

  await createUser({
    email: "teller@koperasi.id",
    name: "Teller",
    password: "teller123",
    roles: ["TELLER"],
    companyId: company.id,
  })

  await createUser({
    email: "manager@koperasi.id",
    name: "Manager",
    password: "manager123",
    roles: ["MANAGER"],
    companyId: company.id,
  })

  await prisma.kelompok.createMany({
    data: [
      {
        companyId: company.id,
        kode: "KL-001",
        nama: "Kelompok Mentari",
        ketua: "Pak Suryo",
        wilayah: "Wonosobo",
        jadwalPertemuan: "Senin",
      },
      {
