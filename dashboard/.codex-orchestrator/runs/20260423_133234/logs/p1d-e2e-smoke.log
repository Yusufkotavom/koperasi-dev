import { expect, test } from \"@playwright/test\"

const ADMIN_EMAIL = process.env.E2E_ADMIN_EMAIL ?? \"admin@koperasi.id\"
const ADMIN_PASSWORD = process.env.E2E_ADMIN_PASSWORD ?? \"admin123\"

async function loginAsAdmin(page: Parameters<typeof test>[0][\"page\"]) {
  await page.goto(\"/login\")

  await expect(page.getByRole(\"heading\", { name: \"Selamat Datang\" })).toBeVisible()
  await page.getByLabel(\"Email\").fill(ADMIN_EMAIL)
  await page.getByLabel(\"Password\").fill(ADMIN_PASSWORD)
  await page.getByRole(\"button\", { name: /"'^Masuk/ }).click()

  await page.waitForURL("**/dashboard", { timeout: 15_000 })
  await expect(page.getByRole("heading", { name: "Dashboard Overview" })).toBeVisible()
}

test.describe("E2E smoke", () => {
  test("login page renders consistently without hydration warnings", async ({ page }) => {
    const hydrationSignals: string[] = []

    page.on("console", (msg) => {
      const text = msg.text()
      if (/hydration|did not match|server rendered html/i.test(text)) {
        hydrationSignals.push(text)
      }
    })

    page.on("pageerror", (err) => {
      const text = String(err)
      if (/hydration|did not match|server rendered html/i.test(text)) {
        hydrationSignals.push(text)
      }
    })

    await page.goto("/login")

    await expect(page.getByRole("heading", { name: "Selamat Datang" })).toBeVisible()
    await expect(page.getByLabel("Email")).toBeVisible()
    await expect(page.getByLabel("Password")).toBeVisible()
    await expect(page.getByRole("button", { name: "Masuk" })).toBeVisible()
    await expect(page.getByText("Demo:")).toBeVisible()
    await expect(page.getByText("admin@koperasi.id / admin123")).toBeVisible()

    await page.reload()
    await expect(page.getByRole("heading", { name: "Selamat Datang" })).toBeVisible()
    await expect(page.getByText("admin@koperasi.id / admin123")).toBeVisible()

    expect(hydrationSignals).toEqual([])
  })

  test("dashboard requires auth and becomes accessible after login", async ({ page }) => {
    await page.goto("/dashboard")
    await page.waitForURL("**/login")
    await expect(page.getByRole("heading", { name: "Selamat Datang" })).toBeVisible()

    await loginAsAdmin(page)
  })

  test("nasabah list route loads for authenticated user", async ({ page }) => {
    await loginAsAdmin(page)

    await page.goto("/nasabah")
    await expect(page.getByRole("heading", { name: "Master Nasabah" })).toBeVisible()
    await expect(page.getByRole("heading", { name: "Daftar Nasabah" })).toBeVisible()
    await expect(page.getByPlaceholder("Cari nama, NIK, atau nomor anggota...")).toBeVisible()

    const rows = page.locator("tbody tr")
    const rowCount = await rows.count()

    if (rowCount > 1) {
      await expect(rows.first()).toBeVisible()
    } else {
      await expect(page.getByText(/Belum ada data nasabah|Tidak ada nasabah dengan kata kunci/i)).toBeVisible()
    }
  })

  test("dokumen routes are available for authenticated user", async ({ page }) => {
    await loginAsAdmin(page)

    const docsRoutes = [
      { path: "/docs/panduan-pengguna", title: /Panduan Pengguna KoperasiApp/i },
      { path: "/docs/using-superpowers", title: /Panduan Penggunaan `'"\\"'$using-superpowers`/i },
    ]

    for (const route of docsRoutes) {
      const response = await page.goto(route.path)
      expect(response?.ok()).toBeTruthy()
      await expect(page.getByText(route.title)).toBeVisible()
    }
  })
})
EOF

