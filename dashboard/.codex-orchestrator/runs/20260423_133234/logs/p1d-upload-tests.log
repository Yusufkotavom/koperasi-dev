import { auth } from \"@/lib/auth\"
import { uploadFilesToBlob, validateUploadFileWithPolicy } from \"@/lib/blob-upload\"
import { requireCompanyId } from \"@/lib/tenant\"

const MAX_NASABAH_UPLOAD_FILES = 10
const MAX_NASABAH_UPLOAD_SIZE = 5 * 1024 * 1024
const NASABAH_ALLOWED_TYPES = [\"image/jpeg\", \"image/png\", \"image/webp\", \"application/pdf\"] as const

const NASABAH_UPLOAD_POLICY = {
  maxFileSize: MAX_NASABAH_UPLOAD_SIZE,
  allowedTypes: new Set<string>(NASABAH_ALLOWED_TYPES),
}

type UploadDeps = {
  authFn: typeof auth
  uploadFn: typeof uploadFilesToBlob
}

function getNasabahUploadPath(companyId: string) {
  return "'`uploads/nasabah/${companyId}`
}

export async function handleNasabahUpload(req: Request, deps: UploadDeps): Promise<Response> {
  const session = await deps.authFn()
  if (!session) {
    return Response.json({ error: "Unauthorized" }, { status: 401 })
  }

  let companyId: string
  try {
    companyId = requireCompanyId(session).companyId
  } catch (error) {
    const message = error instanceof Error ? error.message : "Unauthorized"
    const status = message === "Unauthorized" ? 401 : 400
    return Response.json({ error: message }, { status })
  }

  const formData = await req.formData()
  const files = formData.getAll("files").filter((v): v is File => v instanceof File)

  if (files.length === 0) {
    return Response.json({ error: "Tidak ada file yang diupload." }, { status: 400 })
  }

  if (files.length > MAX_NASABAH_UPLOAD_FILES) {
    return Response.json({ error: `Maksimal ${MAX_NASABAH_UPLOAD_FILES} file per upload.` }, { status: 400 })
  }

  for (const file of files) {
    const validationError = validateUploadFileWithPolicy(file, NASABAH_UPLOAD_POLICY)
    if (validationError) {
      return Response.json({ error: validationError }, { status: 400 })
    }
  }

  try {
    const uploadedUrls = await deps.uploadFn(files, getNasabahUploadPath(companyId), NASABAH_UPLOAD_POLICY)
    return Response.json({ urls: uploadedUrls })
  } catch (error) {
    const message = error instanceof Error ? error.message : "Upload dokumen gagal."
    return Response.json({ error: message }, { status: 400 })
  }
}

export async function POST(req: Request) {
  return handleNasabahUpload(req, {
    authFn: auth,
    uploadFn: uploadFilesToBlob,
  })
}

export const __testables__ = {
  MAX_NASABAH_UPLOAD_FILES,
  MAX_NASABAH_UPLOAD_SIZE,
  NASABAH_ALLOWED_TYPES,
  getNasabahUploadPath,
}
