import assert from \"node:assert/strict\"
import test from \"node:test\"
import { handleNasabahUpload, __testables__ } from \"../route\"

type MockSession = {
  user?: {
    id?: string
    companyId?: string | null
    roles?: string[]
  }
}

function buildRequest(files: File[] = []) {
  const formData = new FormData()
  for (const file of files) {
    formData.append(\"files\", file)
  }

  return new Request(\"http://localhost/api/upload/nasabah\", {
    method: \"POST\",
    body: formData,
  })
}

function createDeps(overrides?: {
  session?: MockSession | null
  uploadFn?: (files: File[], folder: string, policy?: unknown) => Promise<string[]>
}) {
  const uploadCalls: Array<{ files: File[]; folder: string; policy: unknown }> = []
  const uploadFn =
    overrides?.uploadFn ??
    (async (files: File[], folder: string, policy?: unknown) => {
      uploadCalls.push({ files, folder, policy })
      return files.map((_, index) => "'`https://blob.example/${index}`)
    })

  return {
    uploadCalls,
    deps: {
      authFn: async () => overrides?.session ?? { user: { id: "u-1", companyId: "c-1", roles: ["ADMIN"] } },
      uploadFn,
    },
  }
}

test("returns 401 for unauthorized request", async () => {
  const { deps } = createDeps({ session: null })
  const res = await handleNasabahUpload(buildRequest(), deps)

  assert.equal(res.status, 401)
  assert.deepEqual(await res.json(), { error: "Unauthorized" })
})

test("returns 400 when no files uploaded", async () => {
  const { deps } = createDeps()
  const res = await handleNasabahUpload(buildRequest(), deps)

  assert.equal(res.status, 400)
  assert.deepEqual(await res.json(), { error: "Tidak ada file yang diupload." })
})

test("returns 400 for invalid mime type", async () => {
  const badFile = new File(["halo"], "catatan.txt", { type: "text/plain" })
  const { deps } = createDeps()
  const res = await handleNasabahUpload(buildRequest([badFile]), deps)

  assert.equal(res.status, 400)
  assert.deepEqual(await res.json(), { error: "Tipe file tidak didukung: catatan.txt" })
})

test("returns 400 when file count exceeds max", async () => {
  const files = Array.from({ length: __testables__.MAX_NASABAH_UPLOAD_FILES + 1 }, (_, index) =>
    new File([`f-${index}`], `f-${index}.png`, { type: "image/png" }),
  )

  const { deps } = createDeps()
  const res = await handleNasabahUpload(buildRequest(files), deps)

  assert.equal(res.status, 400)
  assert.deepEqual(await res.json(), {
    error: `Maksimal ${__testables__.MAX_NASABAH_UPLOAD_FILES} file per upload.`,
  })
})

test("returns 400 when file size exceeds max", async () => {
  const tooLarge = new File([new Uint8Array(__testables__.MAX_NASABAH_UPLOAD_SIZE + 1)], "besar.png", {
    type: "image/png",
  })

  const { deps } = createDeps()
  const res = await handleNasabahUpload(buildRequest([tooLarge]), deps)

  assert.equal(res.status, 400)
  assert.deepEqual(await res.json(), { error: "Ukuran file melebihi 5 MB: besar.png" })
})

test("returns urls on success and uses tenant-aware upload path", async () => {
  const image = new File(["abc"], "ktp.png", { type: "image/png" })
  const { deps, uploadCalls } = createDeps({
    session: { user: { id: "u-1", companyId: "company-123", roles: ["ADMIN"] } },
  })

  const res = await handleNasabahUpload(buildRequest([image]), deps)

  assert.equal(res.status, 200)
  assert.deepEqual(await res.json(), { urls: ["https://blob.example/0"] })
  assert.equal(uploadCalls.length, 1)
  assert.equal(uploadCalls[0].folder, __testables__.getNasabahUploadPath("company-123"))
})
