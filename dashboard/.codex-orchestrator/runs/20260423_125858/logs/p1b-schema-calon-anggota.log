model Nasabah {
  id            String        @id @default(cuid())
  nomorAnggota  String
  namaLengkap   String
  nik           String
  tempatLahir   String?
  tanggalLahir  DateTime?
  alamat        String
  kelurahan     String?
  kecamatan     String?
  kotaKab       String?
  noHp          String
  pekerjaan     String?
  namaUsaha     String?
  status        StatusNasabah @default(AKTIF)
  tanggalGabung DateTime      @default(now())
  fotoUrl       String?
  dokumenUrls   String[]
  kolektorId    String?
  kelompokId    String?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
  companyId     String
  company       Company       @relation(fields: [companyId], references: [id], onDelete: Cascade)
  kelompok      Kelompok?     @relation(fields: [kelompokId], references: [id])
  kolektor      User?         @relation("KolektorNasabah", fields: [kolektorId], references: [id])
  pengajuan     Pengajuan[]
  penjamin      Penjamin[]
  simpanan      Simpanan[]

  @@unique([companyId, nomorAnggota])
  @@unique([companyId, nik])
  @@index([companyId])
  @@map("nasabah")
}

model Penjamin {
  id          String  @id @default(cuid())
  namaLengkap String
  nik         String
  hubungan    String
  noHp        String
  alamat      String?
  nasabahId   String
  companyId   String
  company     Company @relation(fields: [companyId], references: [id], onDelete: Cascade)
  nasabah     Nasabah @relation(fields: [nasabahId], references: [id], onDelete: Cascade)

  @@index([companyId])
  @@map("penjamin")
}

model Kelompok {
  id              String      @id @default(cuid())
  kode            String
  nama            String
  ketua           String?
  wilayah         String?
  jadwalPertemuan String?
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt
  companyId       String
  company         Company     @relation(fields: [companyId], references: [id], onDelete: Cascade)
  nasabah         Nasabah[]
  pengajuan       Pengajuan[]

  @@unique([companyId, kode])
  @@index([companyId])
  @@map("kelompok")
}

model Pengajuan {
  id                   String          @id @default(cuid())
  nomorPengajuan       String          @unique @default(cuid())
  nasabahId            String
  kelompokId           String?
