name: Quality Gate

on:
  pull_request:
  push:
    branches:
      - main
      - develop

concurrency:
  group: quality-gate-"'${{ github.ref }}
  cancel-in-progress: true

jobs:
  quality-gate:
    name: Lint, Build, and Test (if available)
    runs-on: ubuntu-latest
    timeout-minutes: 20

    steps:
      - name: Checkout
        uses: actions/checkout@v4

      - name: Setup Node.js
        uses: actions/setup-node@v4
        with:
          node-version: 22
          cache: npm

      - name: Install dependencies
        run: npm ci

      - name: Detect optional test script
        id: detect_test
        run: |
          if npm run --silent test >/dev/null 2>&1; then
            echo "has_test=true" >> "$GITHUB_OUTPUT"
          else
            echo "has_test=false" >> "$GITHUB_OUTPUT"
          fi

      - name: Run lint
        run: npm run lint

      - name: Run build
        run: npm run build

      - name: Run tests
        if: steps.detect_test.outputs.has_test == '"'true'
        run: npm run test

      - name: Test script not found
        if: steps.detect_test.outputs.has_test "'!= '"'true'
        run: echo \"No test script in package.json. Skipping tests by design.\"
