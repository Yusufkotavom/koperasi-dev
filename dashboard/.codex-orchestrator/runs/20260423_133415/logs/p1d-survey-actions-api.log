model Simpanan {
  id        String   @id @default(cuid())
  nasabahId String
  jenis     String
  jumlah    Decimal  @db.Decimal(15, 2)
  tanggal   DateTime @default(now())
  companyId String
  company   Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  nasabah   Nasabah  @relation(fields: [nasabahId], references: [id])

  @@index([companyId])
  @@map("simpanan")
}

model Account {
  id           String            @id @default(cuid())
  code         String
  name         String
  type         AccountType
  isActive     Boolean           @default(true)
  createdAt    DateTime          @default(now())
  updatedAt    DateTime          @updatedAt
  companyId    String
  company      Company           @relation(fields: [companyId], references: [id], onDelete: Cascade)
  journalLines JournalLine[]
  kasKategori  KasKategori[]
  rekonsiliasi RekonsiliasiKas[]

  @@unique([companyId, code])
  @@index([type, isActive])
  @@index([companyId])
  @@map("accounts")
}

model JournalEntry {
  id          String            @id @default(cuid())
  entryNo     String            @unique @default(cuid())
  entryDate   DateTime
  description String
  sourceType  JournalSourceType
  sourceId    String?
  status      JournalStatus     @default(POSTED)
  postedById  String?
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt
  companyId   String
  company     Company           @relation(fields: [companyId], references: [id], onDelete: Cascade)
  postedBy    User?             @relation("JournalPostedBy", fields: [postedById], references: [id])
  lines       JournalLine[]

  @@unique([sourceType, sourceId])
  @@index([entryDate])
  @@index([sourceType, sourceId])
  @@index([companyId])
  @@map("journal_entries")
}

model JournalLine {
  id             String       @id @default(cuid())
  journalEntryId String
  accountId      String
  debit          Decimal      @default(0) @db.Decimal(15, 2)
  credit         Decimal      @default(0) @db.Decimal(15, 2)
  memo           String?
  createdAt      DateTime     @default(now())
  account        Account      @relation(fields: [accountId], references: [id])
  journalEntry   JournalEntry @relation(fields: [journalEntryId], references: [id], onDelete: Cascade)

  @@index([journalEntryId])
  @@index([accountId])
  @@map("journal_lines")
}

model RekonsiliasiKas {
  id             String             @id @default(cuid())
  accountId      String
  periodMonth    Int
  periodYear     Int
  saldoStatement Decimal            @db.Decimal(15, 2)
  saldoBook      Decimal            @db.Decimal(15, 2)
  selisih        Decimal            @db.Decimal(15, 2)
  catatan        String?
  buktiUrl       String?
  status         RekonsiliasiStatus @default(DRAFT)
  createdById    String
  createdAt      DateTime           @default(now())
  updatedAt      DateTime           @updatedAt
  companyId      String
  account        Account            @relation(fields: [accountId], references: [id], onDelete: Cascade)
  company        Company            @relation(fields: [companyId], references: [id], onDelete: Cascade)
  createdBy      User               @relation("RekonsiliasiCreatedBy", fields: [createdById], references: [id], onDelete: Cascade)

  @@unique([accountId, periodMonth, periodYear], map: "rekonsiliasi_kas_account_period_key")
  @@index([companyId])
  @@index([periodYear, periodMonth], map: "rekonsiliasi_kas_period_idx")
  @@map("rekonsiliasi_kas")
}

model KasKategori {
  id           String         @id @default(cuid())
  nama         String
  key          String
  jenis        JenisKas
  isActive     Boolean        @default(true)
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt
  accountId    String?
  companyId    String
  account      Account?       @relation(fields: [accountId], references: [id])
  company      Company        @relation(fields: [companyId], references: [id], onDelete: Cascade)
  kasTransaksi KasTransaksi[]

  @@unique([companyId, key])
  @@index([companyId])
  @@map("kas_kategori")
}

model KasTransaksi {
  id          String      @id @default(cuid())
  tanggal     DateTime    @default(now())
  jenis       JenisKas
  kategoriKey String
  deskripsi   String
  jumlah      Decimal     @db.Decimal(15, 2)
  kasJenis    String      @default("TUNAI")
  buktiUrl    String?
  inputOlehId String
  isApproved  Boolean     @default(true)
  referensiId String?
  createdAt   DateTime    @default(now())
  companyId   String
  kategoriId  String
  company     Company     @relation(fields: [companyId], references: [id], onDelete: Cascade)
  inputOleh   User        @relation(fields: [inputOlehId], references: [id])
  kat         KasKategori @relation(fields: [kategoriId], references: [id])

  @@index([companyId])
  @@index([kategoriId])
  @@map("kas_transaksi")
}

model AuditLog {
  id         String      @id @default(cuid())
  actorId    String?
  entityType String
  entityId   String?
  action     AuditAction
  beforeData Json?
  afterData  Json?
  metadata   Json?
  ipAddress  String?
  createdAt  DateTime    @default(now())
  actor      User?       @relation("AuditActor", fields: [actorId], references: [id])

  @@index([entityType, entityId])
  @@index([actorId, createdAt])
  @@map("audit_logs")
}

model ApprovalLog {
  id            String             @id @default(cuid())
  entityType    ApprovalEntityType
  entityId      String
  status        ApprovalStatus     @default(PENDING)
  catatan       String?
  requestedById String
  approvedById  String?
  createdAt     DateTime           @default(now())
  updatedAt     DateTime           @updatedAt
  approvedBy    User?              @relation("ApprovalApprover", fields: [approvedById], references: [id])
  requestedBy   User               @relation("ApprovalRequester", fields: [requestedById], references: [id], onDelete: Cascade)

  @@index([entityType, entityId])
  @@index([requestedById, createdAt])
  @@map("approval_logs")
}

model KolektorTarget {
  id                 String   @id @default(cuid())
  kolektorId         String
  periodMonth        Int
  periodYear         Int
  targetTagihan      Decimal  @db.Decimal(15, 2)
  realisasiTagihan   Decimal  @default(0) @db.Decimal(15, 2)
  targetKunjungan    Int      @default(0)
  realisasiKunjungan Int      @default(0)
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
  companyId          String
  company            Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  kolektor           User     @relation("KolektorTargetUser", fields: [kolektorId], references: [id], onDelete: Cascade)

  @@unique([kolektorId, periodMonth, periodYear])
  @@index([periodYear, periodMonth])
  @@index([companyId])
  @@map("kolektor_targets")
}

model Notifikasi {
  id        String          @id @default(cuid())
  userId    String?
  jenis     NotifikasiJenis
  judul     String
  pesan     String
  link      String?
  isRead    Boolean         @default(false)
  readAt    DateTime?
  createdAt DateTime        @default(now())
  companyId String
  company   Company         @relation(fields: [companyId], references: [id], onDelete: Cascade)
  user      User?           @relation("UserNotifikasi", fields: [userId], references: [id])

  @@index([userId, isRead, createdAt])
  @@index([companyId])
  @@map("notifikasi")
}

model AppSetting {
  key       String   @id
  value     Json
  updatedAt DateTime @default(now()) @updatedAt @db.Timestamptz(6)

  @@map("app_settings")
}

model CompanySetting {
  id        String   @id @default(cuid())
  companyId String
  key       String
  value     Json
  updatedAt DateTime @updatedAt
  company   Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@unique([companyId, key])
  @@index([key])
  @@map("company_settings")
}

