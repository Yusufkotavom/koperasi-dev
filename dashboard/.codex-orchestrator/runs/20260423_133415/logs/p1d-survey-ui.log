  return clean.split("/").filter(Boolean).pop() ?? url
}

type FormNasabah = {
  id: string
  namaLengkap: string
  nik: string
  tempatLahir: string | null
  tanggalLahir: Date | null
  alamat: string
  kelurahan: string | null
