model Company {
  id              String            @id @default(cuid())
  name            String
  slug            String            @unique
  address         String?
  phone           String?
  email           String?
  isActive        Boolean           @default(true)
  ownerId         String
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt
  status          CompanyStatus     @default(ACTIVE)
  suspendedAt     DateTime?
  suspendedReason String?
  suspendedUntil  DateTime?
  deletedAt       DateTime?
  deletedReason   String?
  accounts        Account[]
  owner           User              @relation("CompanyOwner", fields: [ownerId], references: [id])
  settings        CompanySetting[]
  jadwalAngsuran  JadwalAngsuran[]
  journalEntries  JournalEntry[]
  kasKategori     KasKategori[]
  kasTransaksi    KasTransaksi[]
  kelompok        Kelompok[]
  kolektorTargets KolektorTarget[]
  nasabah         Nasabah[]
  nasabahSurveyNotes NasabahSurveyNote[]
  notifikasi      Notifikasi[]
  pembayaran      Pembayaran[]
  pengajuan       Pengajuan[]
  penjamin        Penjamin[]
  pinjaman        Pinjaman[]
  rekonsiliasi    RekonsiliasiKas[]
  simpanan        Simpanan[]
  users           User[]            @relation("UserCompany")

  @@index([ownerId])
  @@map("companies")
}

model User {
  id                     String            @id @default(cuid())
  name                   String
  email                  String            @unique
  password               String
  isActive               Boolean           @default(true)
  createdAt              DateTime          @default(now())
  updatedAt              DateTime          @updatedAt
  companyId              String?
  approvalApproved       ApprovalLog[]     @relation("ApprovalApprover")
  approvalRequested      ApprovalLog[]     @relation("ApprovalRequester")
  auditLogs              AuditLog[]        @relation("AuditActor")
  ownedCompanies         Company[]         @relation("CompanyOwner")
  journalPosted          JournalEntry[]    @relation("JournalPostedBy")
  kasDiinput             KasTransaksi[]
  kolektorTargets        KolektorTarget[]  @relation("KolektorTargetUser")
  nasabahSebagaiKolektor Nasabah[]         @relation("KolektorNasabah")
  nasabahSurveyNotes      NasabahSurveyNote[] @relation("NasabahSurveyNoteActor")
  notifikasi             Notifikasi[]      @relation("UserNotifikasi")
  pembayaranDiinput      Pembayaran[]
  pengajuanDisetujui     Pengajuan[]       @relation("ApproverPengajuan")
  pengajuanDisurvey      Pengajuan[]       @relation("SurveyorPengajuan")
  rekonsiliasiDibuat     RekonsiliasiKas[] @relation("RekonsiliasiCreatedBy")
  roles                  UserRole[]
  company                Company?          @relation("UserCompany", fields: [companyId], references: [id])

  @@index([companyId])
  @@map("users")
}

model Nasabah {
  id            String        @id @default(cuid())
  nomorAnggota  String
  namaLengkap   String
  nik           String
  tempatLahir   String?
  tanggalLahir  DateTime?
  alamat        String
  kelurahan     String?
  kecamatan     String?
  kotaKab       String?
  noHp          String
  pekerjaan     String?
  namaUsaha     String?
  status        StatusNasabah @default(AKTIF)
  tanggalGabung DateTime      @default(now())
  fotoUrl       String?
  dokumenUrls   String[]
  kolektorId    String?
  kelompokId    String?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
  companyId     String
  company       Company       @relation(fields: [companyId], references: [id], onDelete: Cascade)
  kelompok      Kelompok?     @relation(fields: [kelompokId], references: [id])
  kolektor      User?         @relation("KolektorNasabah", fields: [kolektorId], references: [id])
  pengajuan     Pengajuan[]
  penjamin      Penjamin[]
  simpanan      Simpanan[]
  surveyNotes   NasabahSurveyNote[]

  @@unique([companyId, nomorAnggota])
  @@unique([companyId, nik])
  @@index([companyId])
  @@map("nasabah")
}

model NasabahSurveyNote {
  id        String   @id @default(cuid())
  nasabahId String
  companyId String
  actorId   String?
  note      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  actor     User?    @relation("NasabahSurveyNoteActor", fields: [actorId], references: [id], onDelete: SetNull)
